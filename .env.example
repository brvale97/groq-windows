GROQ_API_KEY=zet-hier-je-groq-api-key

# Snel en meertalig. Gebruik whisper-large-v3 als je maximale nauwkeurigheid wilt.
GROQ_MODEL=whisper-large-v3-turbo

# Optioneel. Voor Nederlands: nl. Leeglaten kan ook, dan detecteert Whisper zelf.
GROQ_LANGUAGE=nl

# Optioneel. Helpt met namen/termen/spelling; max ongeveer 224 tokens.
GROQ_PROMPT=

# Standaard: Insert start/stop.
DICTATION_SHORTCUT=insert

# Optioneel. Zet op een device-index uit de startup-lijst, bijvoorbeeld 11.
DICTATION_INPUT_DEVICE=

# 16 kHz mono WAV is snel en past bij Groq STT.
DICTATION_SAMPLE_RATE=16000
DICTATION_CHANNELS=1

# Zet op false als je alleen clipboard-backup wilt zonder automatisch plakken.
PASTE_AFTER_TRANSCRIPTION=true
